LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=

# Fallback opcional (Gemini -> Groq -> Anthropic -> OpenAI, nessa ordem),
# ver config.py::get_llm(). Cada linha só entra na cadeia de fallback se a
# respectiva chave estiver preenchida -- deixar tudo em branco (cenário
# mínimo de testes/prototipagem, só com o Gemini gratuito) é válido e não
# quebra nada.

# Groq -- 2º provedor gratuito, recomendado pra testar o agente com um LLM
# de verdade além do Gemini (hospeda modelos open-source como Llama num
# chip próprio de inferência rápida). Chave em https://console.groq.com
GROQ_API_KEY=
LLM_FALLBACK_GROQ_MODEL=llama-3.3-70b-versatile

# Reforço pago (opcional, ex: pra demonstração) -- não é necessário pra
# rodar/testar o agente localmente.
ANTHROPIC_API_KEY=
LLM_FALLBACK_ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=
LLM_FALLBACK_OPENAI_MODEL=gpt-4o-mini

# BIOTECPREDICT_DB_PATH aponta pro arquivo SQLite exportado do BiotecPredict
# (schema real), colocado manualmente em data/. Nunca versionar esse arquivo.
BIOTECPREDICT_DB_PATH=data/biotecpredict.db
